  "report_editorial": {
    "hverdagsliv": {
      "body": "Coop Mega på Valentinlyst senter er dagligvareankeret, og Extra Elgeseter tar den raske handelen på vei hjem fra byen. Vitusapotek Rosenborg dekker apotekbehovet i gangavstand, og for større ærender ligger Solsiden Senter en kort sykkeltur ned bakkene.",
      "highlightCandidates": ["google-ChIJIXixBrIxbUYRnjSMCB3ZQ18", "google-ChIJnW_zJ20xbUYRqaLffSVJpgY", "google-ChIJvzJ0jU4xbUYRutTE40eFmtY", "google-ChIJt7DE2HQxbUYRX-vo1WjOuJs", "google-ChIJNaI9sMAxbUYRHPEXD_8Vpns", "google-ChIJyVBZnZ8xbUYRhB-s_crA_YQ"]
    },
    "barn-oppvekst": {
      "body": "Barnehagedekningen er tett — Singsaker barnehage ligger rett rundt hjørnet, og lekeplassen på Tyholtsletta er et naturlig samlingspunkt for de minste. Blussuvoll skole tar ungdomstrinnet i gangavstand, og Strinda videregående ligger midt i strøket.",
      "highlightCandidates": ["27ad6e9f-d679-41fc-9d9d-26d296303db5", "38a0120c-80a0-41dc-8391-ca91ba006ffe", "lekeplass-tyholtsletta-lek", "lekeplass-casparis-gate-lek", "1f233179-5b81-4e2c-8321-97b92804ec05", "da3ebb05-9912-443d-b716-1e8bd9d84238"]
    },
    "mat-drikke": {
      "body": "Egon Tårnet serverer med roterende utsikt øverst i Tyholttårnet, og Mikalsen bakery er strøkets eget nærbakeri. Ned bakkene mot Bakklandet ligger Den Gode Nabo og Antikvariatet ved elvekanten, med servering tett i tett langs brosteinen.",
      "highlightCandidates": ["google-ChIJDbaoXbAxbUYRBrj5RuwmdX0", "google-ChIJV1TG4LkxbUYRum_wNynE6Ck", "google-ChIJnSfpw5kxbUYRrD-oYXLVPTI", "google-ChIJtTyDwJkxbUYRSfa9a56pD5o", "google-ChIJLQ4nRZExbUYRSgmHL4nXOOw", "google-ChIJs-DHJJ8xbUYRslPZTW18HJo"]
    },
    "natur-friluftsliv": {
      "body": "Kuhaugen er strøkets egen utsiktstopp med akebakker og åpne sletter, og Estenstadmarka ligger like øst for bebyggelsen. Festningsparken og Høgskoleparken rammer inn strøket mot sentrum, og Gåsaparken på Møllenberg er en grønn lomme mellom trehusene.",
      "highlightCandidates": ["osm-relation-1454974", "google-ChIJ6wsDrAYxbUYRps_kNnZyGVk", "park-h-gskoleparken", "google-ChIJ_1P-25kxbUYRagrpt5QdhhU", "google-ChIJq6pqV7kxbUYRSJUxhPCMm4Y", "google-ChIJCwcJ_KExbUYRKCS3tDVAk4s"]
    },
    "transport": {
      "body": "Bussene mot sentrum går fra Jonsvannsveien, bare et par minutters gange unna. Bysykkelstasjonene på Singsaker og ved Tyholttårnet kobler strøket på sykkelnettet, og fra Lerkendal stasjon går lokaltoget gjennom byen. Det meste av sentrum nås på sykkel i én bakke ned.",
      "highlightCandidates": ["bus-jonsvannsveien", "bysykkel-29", "entur-NSR-StopPlace-43478", "bysykkel-89", "entur-NSR-StopPlace-469", "bus-tyholt"]
