  "report_editorial": {
    "hverdagsliv": {
      "body": "Extra Charlottenlund tar hverdagshandelen midt i strøket, med frisør og pizzeria som naboer. Trenger du mer, ligger storhandelen i hver sin ende: Sirkus Shopping og Lade Arena ved Leangen, og kjøpesenteret på Grilstad mot sjøsiden i øst. Apotek finner du både på Sirkus og på Grilstad.",
      "highlightCandidates": ["google-ChIJi7hv7WcwbUYR9ya9nK8gS88", "google-ChIJVZdRQJoxbUYRTcToJ4smjeM", "google-ChIJt6hpxVMxbUYRDEs-lLem5g8", "google-ChIJqeBnd_4wbUYRR06hK76o-c0", "google-ChIJTd-l4P8wbUYRfp1y1hLVyMI", "google-ChIJAbH6jGcwbUYRydTpQGg-4ro"]
    },
    "barn-oppvekst": {
      "body": "Hele skoleløpet ligger i strøket: Charlottenlund barneskole, Charlottenlund ungdomsskole på Tunvegen og Charlottenlund videregående — en komplett skolevei uten å bytte nabolag. Barnehagene ligger spredt i boligfeltene, fra Charlottenlund barnehage oppe i lia til Grillstadfjæra barnehage ved sjøen, og lekeplassene følger gatene.",
      "highlightCandidates": ["d68664e4-2f08-4a75-8c6d-6ba01ebdb669", "fb548226-d979-4d54-aed2-7b67a7588635", "732146df-82c9-4a51-b26d-0da32912ad44", "2aa32541-6473-4e11-a3d9-4b075779cee7", "ffb79e76-360c-4d47-acde-17e1a3c9836a", "lekeplass-bukken-bruses-veg-lek"]
    },
    "mat-drikke": {
      "body": "Det nære utvalget er hverdagsvennlig: Pizzapizza og Sabrura med sushi-takeaway på Skovgård-siden, og pizzeriaen ved Extra-senteret. Kaféutvalget ligger rett nedi bakken ved Sirkus Shopping, der Jordbærpikene, Dromedar og French Pleasures ligger vegg i vegg.",
      "highlightCandidates": ["google-ChIJ37A9KgAxbUYRFGeb6tZtAq8", "google-ChIJsaSF7xIxbUYRqmz-Ex9HFuk", "google-ChIJqeBnd_4wbUYR4SUbbftcyoo", "google-ChIJRR076-MxbUYRwmx7ffmyk-U", "google-ChIJi7hv7WcwbUYRXKhCKlVE0ek", "google-ChIJg5CWMQAxbUYRL32vaOxOq_M"]
    },
    "natur-friluftsliv": {
      "body": "Strøket heller ned mot fjorden, der Rotvollfjæra og Devlebukta åpner sjøsiden, og Ladestien fortsetter østover mot Grillstadfjæra og badeplassen på Grilstadstranda. I strøkets vestre kant ligger parkanlegget rundt Leangen gård.",
      "highlightCandidates": ["badeplass-rotvollfj-ra", "badeplass-devlebukta", "E5F5BBBB-646B-421F-93A4-5508B03182DB", "park-grillstadfj-ra", "badeplass-grilstadstranda", "park-leangen-gard-park"]
    },
    "transport": {
      "body": "Leangen stasjon ligger i strøkets nedre kant, med lokaltog mot sentrum den ene veien og Værnes og Stjørdal den andre. Bussene dekker resten av strøket — holdeplassene følger Ranheimsvegen og Jakobslivegen, fra Nedre Charlottenlund til Skovgård — og bysykkelen står på Falkenborg.",
      "highlightCandidates": ["entur-NSR-StopPlace-393", "bus-nedre-charlottenlund", "bus-churchills-veg", "bus-skovgard", "bysykkel-56", "bus-tunvegen"]
    },
    "trening-aktivitet": {
      "body": "3T Leangen er strøkets store treningssenter, med Impulse både ved Leangen og på Grilstad-siden. ULF-AN bokseklubb holder til i kjelleren på Charlottenlundhallen, og Trondheim Performance Center og The Norwegian Combat Academy dekker dem som vil trene mer spesialisert.",
      "highlightCandidates": ["google-ChIJUdaOG_8wbUYRthFAqcjZ5kM", "google-ChIJHz_sFQAxbUYRd40wV09bXZw", "google-ChIJ2wDh0f8wbUYRlfCrsUTpnnQ", "google-ChIJUS3PKPAxbUYRBtMXHjRDc2g", "google-ChIJzecRTlQxbUYRfVhcZo38UcE", "google-ChIJXctPUYowbUYRr9WGctzKmVM"]
    }
