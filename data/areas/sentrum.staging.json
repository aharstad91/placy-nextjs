  "report_editorial": {
    "hverdagsliv": {
      "body": "Trondheim Torg ligger midt i strøket med dagligvare og butikker under ett tak, og Byhaven få kvartaler unna. Extra på Leuthenhaven dekker den raske handleturen, Boots Apotek ligger rett ved Torvet, og på elvesiden samler Solsiden Senter med MENY resten av hverdagshandelen.",
      "highlightCandidates": ["google-ChIJS1CB5ZoxbUYR-PEX9qTtNcA", "google-ChIJj_IGzpoxbUYR7VCF93NHcjU", "google-ChIJZ_BGgJwxbUYRbSBTqdYtKOA", "google-ChIJk3NQuZsxbUYROdku5-fvUw8", "google-ChIJyVBZnZ8xbUYRhB-s_crA_YQ", "google-ChIJm6lLfZ8xbUYRFYo0NaeG5sk"]
    },
    "barn-oppvekst": {
      "body": "Bispehaugen skole er strøkets barneskole, og barnehagedekningen er tett: Midtbyen barnehage, Midtbyen åpen barnehage og Birralee International Kindergarten ligger alle i gangavstand. Lekeplassene i Stiftsgårdsparken og på Peter Egges plass gir småbarnsfamiliene grønne pauserom midt i bykjernen.",
      "highlightCandidates": ["a6aaee48-2b4f-47e0-b395-7f4aa4485e09", "8afbe4cf-945e-4f48-9c3e-add76d6c8adb", "aafb3a6b-1063-4c8b-939b-b86ff9272def", "73135b16-41ba-4fa1-bd9e-c9687dc7109b", "lekeplass-stiftgardsparken-lek", "lekeplass-peter-egges-plass-lek"]
    },
    "mat-drikke": {
      "body": "Spisestedene ligger tettere her enn noe annet sted i byen: Hevd har bakeriutsalg rett ved Torvet, Dromedar Kaffebar ligger på Nordre, og Frati serverer italiensk i Munkegata. På Bakklandet ligger Baklandet Skydsstation og Den Gode Nabo ved elvekanten, og Spontan Wine Bar skjenker naturvin noen kvartaler unna.",
      "highlightCandidates": ["google-ChIJoREGE-kxbUYRMYSz0NwYXlQ", "google-ChIJu4I8x5kxbUYR_tiYBcnkTUw", "google-ChIJ2aQDbZsxbUYR_E7u1o0O8Ac", "google-ChIJqb152pkxbUYRPnGsWN9VfPQ", "google-ChIJnSfpw5kxbUYRrD-oYXLVPTI", "google-ChIJL1KydZsxbUYRhHOA_U_hHgg"]
    },
